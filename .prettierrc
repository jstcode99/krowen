{
	"useTabs": true,
	"singleQuote": true,
	"trailingComma": "none",
	"printWidth": 100,
	"plugins": ["prettier-plugin-svelte", "prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": "*.svelte, *.ts, *.js, *.css",
			"options": {
				"parser": "svelte, typescript, javascript, css"
			}
		}
	],
	"tailwindStylesheet": "./src/lib/styles/layout.css"
}
